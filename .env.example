# Postgres (matches docker-compose.yml defaults)
# Host port defaults to 5456 to avoid clashing with other local Postgres installs (5432/5433/5455).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_PORT=5456
DATABASE_URL=postgresql://postgres:postgres@localhost:5456/app

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Auth (JWT)
# Generate a real one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=15m
# How long a refresh token stays valid (days) — rotated on every use, revoked on logout.
JWT_REFRESH_EXPIRES_DAYS=30

# Rate limiting — global default (requests per window, per IP).
# Register/login have a separate, fixed, stricter limit (5 req/60s) hardcoded in AuthController.
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging — pino level: debug | info | warn | error
LOG_LEVEL=info

# Email (optional) — verification + password reset emails.
# Without these set, emails are logged to the console instead of sent — no setup needed to try the flow locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
